# Riot Games API key (personal key — expires every 24h; get one at developer.riotgames.com)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Your Riot ID (gameName#tagLine, e.g. Faker#KR1).
# MUST be quoted — the '#' is otherwise parsed as an inline comment and the tag is dropped.
RIOT_ID="YourName#TAG"

# League of Legends platform (e.g. euw1, na1, kr)
PLATFORM=euw1

# Riot API regional route matching your platform (euw1/eun1/tr1/ru → europe; na1/br1/la1/la2/oc1 → americas; kr/jp1 → asia)
REGION=europe
